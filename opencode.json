{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest",
    "opencode-wakatime",
    "opencode-antigravity-auth@latest",
    "opencode-antigravity-quota@latest"
  ],
  "provider": {
    "google": {
      "npm": "@ai-sdk/google",
      "name": "Google",
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "low": {
              "thinkingLevel": "low"
            },
            "high": {
              "thinkingLevel": "high"
            }
          }
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "minimal": {
              "thinkingLevel": "minimal"
            },
            "low": {
              "thinkingLevel": "low"
            },
            "medium": {
              "thinkingLevel": "medium"
            },
            "high": {
              "thinkingLevel": "high"
            }
          }
        },
        "antigravity-claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5 (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "antigravity-claude-sonnet-4-5-thinking": {
          "name": "Claude Sonnet 4.5 Thinking (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "low": {
              "thinkingConfig": {
                "thinkingBudget": 8192
              }
            },
            "max": {
              "thinkingConfig": {
                "thinkingBudget": 32768
              }
            }
          }
        },
        "antigravity-claude-opus-4-5-thinking": {
          "name": "Claude Opus 4.5 Thinking (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "low": {
              "thinkingConfig": {
                "thinkingBudget": 8192
              }
            },
            "max": {
              "thinkingConfig": {
                "thinkingBudget": 32768
              }
            }
          }
        }
      }
    }
  },
  "mcp": {
    "tanstack": {
      "type": "remote",
      "url": "https://tanstack.com/api/mcp",
      "headers": {
        "Authorization": "Bearer ts_f0cc3818bb2008621d7de22ea34c5b4ab533bb8e8625ea12172a732e7e0581aa"
      }
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "oauth": {},
      "enabled": false
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "oauth": {},
      "enabled": false
    },
    "emo": {
      "type": "local",
      "command": [
        "npx",
        "--registry",
        "https://bnpm.byted.org",
        "-y",
        "@byted/emo-mcp-server@latest"
      ]
    },
    "bytedance-mcp-bitsai_quoraid": {
      "type": "local",
      "command": [
        "npx",
        "--registry",
        "https://bnpm.byted.org",
        "-y",
        "--no-package-lock",
        "@byted/mcp-proxy@latest"
      ],
      "environment": {
        "MCP_SERVER_PSM": "bytedance.mcp.bitsai_quoraid",
        "MCP_GATEWAY_REGION": "CN",
        "MCP_REQUEST_TIMEOUT_MS": "600000",
        "RUN_MCP_TIMEOUT_MS": "600000"
      },
      "enabled": true,
      "timeout": 10000
    }
  }
}
