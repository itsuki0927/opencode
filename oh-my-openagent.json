{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "google_auth": false,
  "agents": {
    "oracle": {
      "model": "openai/gpt-5.4"
    },
    "explore": {
      "model": "openai/gpt-5.4"
    },
    "sisyphus": {
      "model": "openai/gpt-5.4"
    },
    "librarian": {
      "model": "openai/gpt-5.4"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4"
    },
    "frontend-ui-ux-engineer": {
      "model": "openai/gpt-5.4"
    },
    "document-writer": {
      "model": "openai/gpt-5.4"
    },
    "metis": {
      "model": "openai/gpt-5.4"
    },
    "momus": {
      "model": "openai/gpt-5.4"
    },
    "atlas": {
      "model": "openai/gpt-5.4"
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "variant": "max"
    }
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "experimental": {
    "auto_resume": true
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.4"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "artistry": {
      "model": "openai/gpt-5.4",
      "variant": "max"
    },
    "quick": {
      "model": "openai/gpt-5.4"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4"
    },
    "writing": {
      "model": "openai/gpt-5.4"
    }
  }
}
