      "TraceQuery": {
        "CN": {
          "description": "通过 logid 查询 trace 日志（CN 环境）",
          "output_filter": ".response_body.data",
          "http_request_metadata": {
            "method": "POST",
            "url": "https://logservice.byted.org/streamlog/platform/microservice/v1/query/trace",
            "headerSchema": {
              "type": "object",
              "properties": {
                "x-jwt-token": {
                  "type": "string",
                  "description": "JWT Token（用户身份认证）"
                },
                "content-type": {
                  "type": "string",
                  "default": "application/json",
                  "description": "Content-Type"
                },
                "origin": {
                  "type": "string",
                  "default": "https://cloud.bytedance.net",
                  "description": "Origin header"
                },
                "referer": {
                  "type": "string",
                  "default": "https://cloud.bytedance.net/",
                  "description": "Referer header"
                }
              }
            },
            "bodySchema": {
              "type": "object",
              "properties": {
                "logid": {
                  "type": "string",
                  "description": "要查询的 logid"
                },
                "psm_list": {
                  "type": "array",
                  "items": { "type": "string" },
                  "default": [],
                  "description": "PSM 列表（可选，空数组表示跨服务搜索）"
                },
                "scan_span_in_min": {
                  "type": "integer",
                  "default": 10,
                  "description": "扫描时间范围（分钟）"
                },
                "vregion": {
                  "type": "string",
                  "default": "China-North",
                  "description": "虚拟区域"
                }
              },
              "required": ["logid"]
            },
            "outputSchema": {
              "type": "object",
              "properties": {
                "items": {
                  "type": "array",
                  "description": "Trace 记录列表，每条包含 value[].kv_list[]（key-value 形式的日志字段）"
                }
              }
            }
          }
        },
