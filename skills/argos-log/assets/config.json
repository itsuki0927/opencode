      "KeywordQuery": {
        "CN": {
          "description": "通过关键字搜索日志（CN 环境）",
          "output_filter": ".response_body.data",
          "http_request_metadata": {
            "method": "POST",
            "url": "https://logservice.byted.org/streamlog/platform/microservice/v2/query/log",
            "headerSchema": {
              "type": "object",
              "properties": {
                "x-jwt-token": {
                  "type": "string",
                  "description": "JWT Token（用户身份认证）"
                },
                "content-type": {
                  "type": "string",
                  "default": "application/json",
                  "description": "Content-Type"
                },
                "origin": {
                  "type": "string",
                  "default": "https://cloud.bytedance.net",
                  "description": "Origin header"
                },
                "referer": {
                  "type": "string",
                  "default": "https://cloud.bytedance.net/",
                  "description": "Referer header"
                }
              }
            },
            "bodySchema": {
              "type": "object",
              "properties": {
                "psm_list": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "PSM 列表"
                },
                "start": {
                  "type": "integer",
                  "description": "开始时间（Unix 时间戳，秒）"
                },
                "end": {
                  "type": "integer",
                  "description": "结束时间（Unix 时间戳，秒），end - start ≤ 10800"
                },
                "limit": {
                  "type": "integer",
                  "default": 100,
                  "description": "每页结果数量"
                },
                "keyword_filter": {
                  "type": "object",
                  "description": "关键字过滤条件",
                  "properties": {
                    "include": {
                      "type": "object",
                      "properties": {
                        "case_sensitive": {
                          "type": "boolean",
                          "default": true,
                          "description": "是否大小写敏感"
                        },
                        "operator": {
                          "type": "string",
                          "default": "AND",
                          "description": "逻辑运算符（AND/OR）"
                        },
                        "word_list": {
                          "type": "array",
                          "description": "关键字列表",
                          "items": {
                            "type": "object",
                            "properties": {
                              "word": { "type": "string", "description": "关键字" },
                              "is_term": { "type": "boolean", "default": false, "description": "是否精确匹配" }
                            }
                          }
                        }
                      }
                    },
                    "exclude": {
                      "type": "object",
                      "properties": {
                        "words": { "type": "array", "default": [], "description": "排除关键字" },
                        "case_sensitive": { "type": "boolean", "default": true },
                        "operator": { "type": "string", "default": "AND" }
                      }
                    }
                  }
                },
                "kv_filters": {
                  "type": "array",
                  "description": "KV 过滤条件列表",
                  "items": {
                    "type": "object",
                    "properties": {
                      "key": { "type": "string", "description": "过滤 key（如 _idc, _cluster）" },
                      "type": { "type": "string", "default": "STRING" },
                      "operator": { "type": "string", "default": "in" },
                      "value": { "type": "array", "items": { "type": "string" }, "description": "过滤值列表" }
                    }
                  }
                },
                "context": {
                  "type": "array",
                  "default": [],
                  "description": "分页上下文（首次查询传空数组，后续传上一次返回的 context）"
                },
                "data_source_uid": {
                  "type": "string",
                  "default": "",
                  "description": "数据源 UID"
                },
                "enable_index": {
                  "type": "boolean",
                  "default": false,
                  "description": "是否启用索引"
                },
                "timeout_in_ms": {
                  "type": "integer",
                  "default": 2000,
                  "description": "查询超时（毫秒）"
                },
                "vregion": {
                  "type": "string",
                  "default": "China-North",
                  "description": "虚拟区域"
                }
              },
              "required": ["psm_list", "start", "end", "keyword_filter", "kv_filters"]
            },
            "outputSchema": {
              "type": "object",
              "properties": {
                "content": {
                  "type": "array",
                  "description": "日志记录列表，每条包含 messages[]（key-value 形式的日志字段）"
                },
                "context": {
                  "type": "array",
                  "description": "分页上下文（非空时可用于下一次查询）"
                }
              }
            }
          }
        },
